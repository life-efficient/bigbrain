{
  "brain_id": "brn_00000000-0000-4000-8000-000000000000",
  "brain_name": "Personal Brain",
  "brain_dir": "/absolute/path/to/your/brain-home",
  "schema_dirs": [
    "people",
    "organizations",
    "deals",
    "projects",
    "ideas",
    "meetings",
    "tasks",
    "concepts",
    "writing",
    "protocol",
    "archive"
  ],
  "storage_backend": "sqlite",
  "database_url_env": "DATABASE_URL",
  "openai_embedding_model": "text-embedding-3-small",
  "openai_query_model": "gpt-4o-mini",
  "freshness_inputs": ["markdown", "meetings", "conversations"],
  "dashboard_port": 3474,
  "lookback_fallback": "24h",
  "include_globs": ["**/*.md"],
  "exclude_globs": [".git/**", "archive/**", ".raw/**"]
}
