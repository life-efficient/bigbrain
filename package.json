{
  "name": "bigbrain",
  "version": "0.15.0",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "bin": {
    "bigbrain": "./bin/bigbrain.js"
  },
  "scripts": {
    "build:dashboard": "node ./scripts/build-dashboard-client.mjs",
    "init": "node ./bin/bigbrain.js init",
    "recent": "node ./bin/bigbrain.js recent",
    "sync": "node ./bin/bigbrain.js sync",
    "schema": "node ./bin/bigbrain.js schema",
    "desktop:dev": "node electron/dev-launcher.cjs",
    "desktop:dist": "npm run build:dashboard && electron-builder --mac dmg zip --universal --publish never",
    "desktop:dir": "electron-builder --mac dir",
    "test": "node --test test/bigbrain/*.test.mjs"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "@tiptap/extension-link": "^3.23.5",
    "@tiptap/extension-table": "^3.23.5",
    "@tiptap/extension-table-cell": "^3.23.5",
    "@tiptap/extension-table-header": "^3.23.5",
    "@tiptap/extension-table-row": "^3.23.5",
    "@tiptap/extension-task-item": "^3.23.5",
    "@tiptap/extension-task-list": "^3.23.5",
    "@tiptap/markdown": "^3.23.5",
    "@tiptap/react": "^3.23.5",
    "@tiptap/starter-kit": "^3.23.5",
    "esbuild": "^0.28.1",
    "js-yaml": "^4.3.0",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vis-network": "^10.1.0"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.0.12"
  },
  "overrides": {
    "undici": "^6.27.0"
  },
  "build": {
    "appId": "ai.diffusing.bigbrain.dashboard",
    "productName": "BigBrain",
    "asar": false,
    "directories": {
      "output": "dist/electron"
    },
    "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
    "files": [
      "bin/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json",
      "README.md",
      "schemas/**/*",
      "src/**/*"
    ],
    "mac": {
      "icon": "electron/assets/desktop-app-icon.icns",
      "category": "public.app-category.productivity",
      "identity": null,
      "hardenedRuntime": false,
      "x64ArchFiles": "Contents/Resources/app/node_modules/**/esbuild",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ]
    }
  },
  "allowScripts": {
    "electron@42.5.0": true
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
